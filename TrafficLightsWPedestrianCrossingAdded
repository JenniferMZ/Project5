// Project 5: Traffic Lights

#define westButton 3
#define eastButton 13
#define westRed 2
#define westYellow 1
#define westGreen 0
#define eastRed 12
#define eastYellow 11
#define eastGreen 10
#define pedWhite 9

#define yellowBlinkTime 500

boolean trafficWest = true;
int flowTime = 5000;    // FIX ME / from 10 000
int changeDelay = 1000;  // FIX ME / from 2000


void setup() 
{
  //set button and LED pins
  pinMode(westButton, INPUT);
  pinMode(westRed, OUTPUT);
  pinMode(westYellow, OUTPUT);
  pinMode(westGreen, OUTPUT);
  pinMode(eastButton, INPUT);
  pinMode(eastRed,OUTPUT);
  pinMode(eastYellow, OUTPUT);
  pinMode(eastGreen, OUTPUT);
  pinMode(pedWhite, OUTPUT);

  //set start state for each light
  digitalWrite(westRed, LOW);
  digitalWrite(westYellow, LOW);
  digitalWrite(westGreen, HIGH);      // traffic West light is Green
  digitalWrite(eastRed, HIGH);        // traffic East light is Red
  digitalWrite(eastYellow, LOW);
  digitalWrite(eastGreen, LOW);
  digitalWrite(pedWhite, LOW);        // ped light is off
}


void loop() 
{
  if (digitalRead(westButton) == HIGH || digitalRead(eastButton) == HIGH)
  {
    if (trafficWest != true)
    {
      trafficWest = true;
      delay (flowTime/2);   // 2.5sec delay between green and yellow
      digitalWrite (eastGreen, LOW);
      digitalWrite (eastYellow, HIGH);
      delay(changeDelay);   // 1sec delay between yellow and red
      digitalWrite (eastYellow, LOW);
      digitalWrite (eastRed, HIGH);
      digitalWrite (pedWhite, HIGH);  // turn on ped light
      delay (flowTime);   // 5sec pedestrian walk gap
      digitalWrite (pedWhite, LOW);   // turn off ped light, resume traffic
      for (int a=0; a<5; a++)
      {
        digitalWrite (westYellow, LOW);
        delay (yellowBlinkTime);
        digitalWrite(westYellow, HIGH);
        delay (yellowBlinkTime);
      }
      digitalWrite (westYellow, LOW);
      digitalWrite (westRed, LOW);
      digitalWrite (westGreen, HIGH);
    }

    else if (trafficWest == true)
    {
      trafficWest = false;
      delay (flowTime/2);   // 2.5sec delay between green and yellow
      digitalWrite (westGreen, LOW);
      digitalWrite (westYellow, HIGH);
      delay (changeDelay);   // 1sec delay between yellow and red
      digitalWrite (westYellow, LOW);
      digitalWrite (westRed, HIGH);
      digitalWrite (pedWhite, HIGH);  // turn on ped light
      delay (flowTime);   // 5sec pedestrian walk gap
      digitalWrite (pedWhite, LOW);   // turn off ped light, resume traffic
      for (int a=0; a<5; a++)
      {
        digitalWrite (eastYellow, LOW);
        delay (yellowBlinkTime);
        digitalWrite (eastYellow, HIGH);
        delay (yellowBlinkTime);
      }
      digitalWrite (eastYellow, LOW);
      digitalWrite (eastRed, LOW);
      digitalWrite (eastGreen, HIGH);
    }
  }
  //if (digitalRead (eastButton) == HIGH)
  {
    
  }

}
