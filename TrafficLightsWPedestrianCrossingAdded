// Project 5: Traffic Lights - attempt with pedestrian crossing

#define westButton 3
#define eastButton 13
#define westRed 2
#define westYellow 5
#define westGreen 4
#define eastRed 12
#define eastYellow 11
#define eastGreen 10
#define pedWhite 9 

unsigned long previousMillis = 0;
unsigned long blinkMillis = 0;
int state = 0;      // 0: West Green, 1: West -> East, 2: East Green, 3: East -> West
int subState = 0;   // 0: Flow, 1: Yellow, 2: Ped Crossing (All Red), 3: Blink Yellow
int blinkCount = 0;
bool transitionRequest = false;

void setup() {
  pinMode(westButton, INPUT_PULLUP);
  pinMode(eastButton, INPUT_PULLUP);
  pinMode(westRed, OUTPUT); pinMode(westYellow, OUTPUT); pinMode(westGreen, OUTPUT);
  pinMode(eastRed, OUTPUT); pinMode(eastYellow, OUTPUT); pinMode(eastGreen, OUTPUT);
  pinMode(pedWhite, OUTPUT); 
  setWestGreen();
}

void loop() {
  unsigned long currentMillis = millis();

  // Check buttons
  if (digitalRead(eastButton) == LOW && state == 0) transitionRequest = true;
  if (digitalRead(westButton) == LOW && state == 2) transitionRequest = true;

  if (transitionRequest) {
    if (state == 0) westToEast(currentMillis);
    if (state == 2) eastToWest(currentMillis);
  }
}

void westToEast(unsigned long now) {
  switch (subState) {
    case 0: // Flow Time (10s)
      if (now - previousMillis >= 10000) {
        digitalWrite(westGreen, LOW);
        digitalWrite(westYellow, HIGH);
        subState = 1;
        previousMillis = now;
      }
      break;
    case 1: // West Yellow (2s)
      if (now - previousMillis >= 2000) {
        digitalWrite(westYellow, LOW);
        digitalWrite(westRed, HIGH); // West is Red
        digitalWrite(eastRed, HIGH); // East is ALREADY Red
        digitalWrite(pedWhite, HIGH); // Pedestrians go!
        subState = 2;
        previousMillis = now;
      }
      break;
    case 2: // ALL RED / Pedestrian Walk (5s)
      if (now - previousMillis >= 5000) {
        digitalWrite(pedWhite, LOW);
        subState = 3;
        blinkCount = 0;
        previousMillis = now;
      }
      break;
    case 3: // Blinking East Yellow (Preparing East Green)
      if (now - blinkMillis >= 500) {
        blinkMillis = now;
        digitalWrite(eastYellow, !digitalRead(eastYellow));
        if (digitalRead(eastYellow) == LOW) blinkCount++; 
      }
      if (blinkCount >= 5) {
        setEastGreen();
        resetTransition();
      }
      break;
  }
}

void eastToWest(unsigned long now) {
  switch (subState) {
    case 0: // Flow Time (10s)
      if (now - previousMillis >= 10000) {
        digitalWrite(eastGreen, LOW);
        digitalWrite(eastYellow, HIGH);
        subState = 1;
        previousMillis = now;
      }
      break;
    case 1: // East Yellow (2s)
      if (now - previousMillis >= 2000) {
        digitalWrite(eastYellow, LOW);
        digitalWrite(eastRed, HIGH); // East is Red
        digitalWrite(westRed, HIGH); // West is ALREADY Red
        digitalWrite(pedWhite, HIGH); // Pedestrians go!
        subState = 2;
        previousMillis = now;
      }
      break;
    case 2: // ALL RED / Pedestrian Walk (5s)
      if (now - previousMillis >= 5000) {
        digitalWrite(pedWhite, LOW);
        subState = 3;
        blinkCount = 0;
        previousMillis = now;
      }
      break;
    case 3: // Blinking West Yellow (Preparing West Green)
      if (now - blinkMillis >= 500) {
        blinkMillis = now;
        digitalWrite(westYellow, !digitalRead(westYellow));
        if (digitalRead(westYellow) == LOW) blinkCount++; 
      }
      if (blinkCount >= 5) {
        setWestGreen();
        resetTransition();
      }
      break;
  }
}

void resetTransition() {
  transitionRequest = false;
  subState = 0;
  blinkCount = 0;
  digitalWrite(pedWhite, LOW);
}

void setWestGreen() {
  digitalWrite(westRed, LOW); digitalWrite(westYellow, LOW); digitalWrite(westGreen, HIGH);
  digitalWrite(eastRed, HIGH); digitalWrite(eastYellow, LOW); digitalWrite(eastGreen, LOW);
  state = 0;
  previousMillis = millis();
}

void setEastGreen() {
  digitalWrite(westRed, HIGH); digitalWrite(westYellow, LOW); digitalWrite(westGreen, LOW);
  digitalWrite(eastRed, LOW); digitalWrite(eastYellow, LOW); digitalWrite(eastGreen, HIGH);
  state = 2;
  previousMillis = millis();
}
